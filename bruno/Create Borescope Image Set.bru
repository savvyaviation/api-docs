meta {
  name: Create Borescope Image Set
  type: http
  seq: 7
}

post {
  url: {{HOST}}/api/borescope/create-image-set/
  body: formUrlEncoded
  auth: none
}

body:form-urlencoded {
  token: {{token}}
  aircraft_id: {{aircraft_id}}
  inspection_date: {{inspection_date}}
  ~hobbs_hours: {{hobbs_hours}}
}

vars:pre-request {
  aircraft_id: 
  inspection_date: 2025-06-15
}
